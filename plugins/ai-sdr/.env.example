# AI SDR Agent Configuration
# Copy this to .env and fill in your API keys

# Google Sheets
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit

# ZeroBounce Email Validation
ZEROBOUNCE_API_KEY=your_zerobounce_api_key

# Smartlead Email Outreach
SMARTLEAD_API_KEY=your_smartlead_api_key
SMARTLEAD_CAMPAIGN_ID=your_campaign_id

# HeyReach LinkedIn Outreach
HEYREACH_API_KEY=your_heyreach_api_key
HEYREACH_LIST_ID=your_list_id

# Notion Output
NOTION_ACCOUNTS_DB_ID=your_notion_accounts_db_id
NOTION_ACCOUNTS_DATASOURCE=your_notion_accounts_datasource_id
NOTION_PROSPECTS_DB_ID=your_notion_prospects_db_id
NOTION_PROSPECTS_DATASOURCE=your_notion_prospects_datasource_id
NOTION_PARENT_PAGE=your_notion_parent_page_id
